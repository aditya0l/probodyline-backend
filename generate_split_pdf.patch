+  async generateSOSplitPDF(
+    soId: string,
+    splitId: string,
+    template: string = 'default',
+  ): Promise<Buffer> {
+    const split = await this.prisma.dispatchSplit.findUnique({
+      where: { id: splitId },
+      include: {
+        items: true,
+        salesOrder: {
+          include: {
+            quotation: {
+              include: {
+                customer: true,
+                items: {
+                  orderBy: { srNo: 'asc' },
+                },
+              },
+            },
+          },
+        },
+      },
+    });
+
+    if (!split || !split.salesOrder || !split.salesOrder.quotation) {
+      throw new NotFoundException('Split or Quotation not found');
+    }
+
+    const quotation = split.salesOrder.quotation;
+
+    // Filter and update items for this split
+    const filteredItems = quotation.items.map(item => {
+      const splitItem = split.items.find(si => si.quotationItemId === item.id);
+      const qty = splitItem ? splitItem.quantity : 0;
+      if (qty <= 0) return null;
+
+      return {
+        ...item,
+        quantity: qty,
+        amount: qty * Number(item.rate || 0) * (1 - Number(item.discount || 0) / 100),
+      };
+    }).filter(Boolean) as QuotationItem[];
+
+    // Recalculate totals
+    const subtotal = filteredItems.reduce((sum, item) => sum + Number(item.amount), 0);
+    const discountAmount = subtotal * (Number(quotation.discount) / 100);
+    let totalBeforeTax = subtotal - discountAmount;
+    
+    let cgstAmount = 0;
+    let sgstAmount = 0;
+    let igstAmount = 0;
+
+    if (quotation.taxType === 'GST') {
+      cgstAmount = totalBeforeTax * 0.09;
+      sgstAmount = totalBeforeTax * 0.09;
+    } else if (quotation.taxType === 'IGST') {
+      igstAmount = totalBeforeTax * 0.18;
+    }
+
+    const finalAmount = totalBeforeTax + cgstAmount + sgstAmount + igstAmount;
+
+    const mockedQuotation = {
+      ...quotation,
+      items: filteredItems,
+      subTotal: subtotal,
+      totalAmount: finalAmount,
+      cgstAmount,
+      sgstAmount,
+      igstAmount,
+    };
+
+    const html = await this.generateQuotationHTML(mockedQuotation, template);
+
+    const executablePath = process.env.PUPPETEER_EXECUTABLE_PATH;
+    const browser = await puppeteer.launch({
+      headless: true,
+      executablePath,
+      args: ['--no-sandbox', '--disable-setuid-sandbox'],
+    });
+
+    try {
+      const page = await browser.newPage();
+      await page.setContent(html, { waitUntil: 'domcontentloaded', timeout: 15000 });
+      const pdf = await page.pdf({ format: 'A4', printBackground: true, margin: { top: '10mm', right: '10mm', bottom: '12mm', left: '10mm' } });
+      return Buffer.from(pdf);
+    } finally {
+      await browser.close();
+    }
+  }
+
